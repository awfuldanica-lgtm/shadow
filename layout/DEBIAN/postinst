#!/usr/bin/env bash

if [[ $DPKG_MAINTSCRIPT_ARCH == "iphoneos-arm64" ]]
then
    DPKG_ROOT="/var/jb"
fi

case "$1" in
    configure)
        chown -R mobile:mobile "$DPKG_ROOT/Library/Shadow"
        chmod -R 0777 "$DPKG_ROOT/Library/Shadow"

        # Remove leftover ShadowSettings PreferenceBundle from older installs.
        # smbc11+ no longer ships it; SMBC bypass is hardcoded in the dylib.
        rm -rf "$DPKG_ROOT/Library/PreferenceBundles/ShadowSettings.bundle" || true

        # Force-allow tweak injection into our target banking apps by setting
        # their value to 0 in roothide's blacklist plist (1 = blocked from
        # tweaks, 0 = inject normally). roothide-manager's toggle is opt-OUT.
        ROOTHIDE_PLIST="/var/mobile/Library/RootHide/RootHideConfig.plist"
        if [ -f "$ROOTHIDE_PLIST" ] && command -v plutil > /dev/null 2>&1; then
            plutil -replace "appconfig.com\\.dnx\\.japan\\.ui\\.bank" -integer 0 "$ROOTHIDE_PLIST" 2>/dev/null || true
            plutil -replace "appconfig.jp\\.co\\.smbc\\.direct" -integer 0 "$ROOTHIDE_PLIST" 2>/dev/null || true
            chown mobile:mobile "$ROOTHIDE_PLIST" || true
        fi

        "$DPKG_ROOT/usr/local/bin/shdw" -g > /dev/null || true
    ;;

    triggered)
        "$DPKG_ROOT/usr/local/bin/shdw" -g > /dev/null || true
    ;;
esac

exit 0
